{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Товары",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "images": {
      "type": "media",
      "multiple": true,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "name": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "longDescription": {
      "type": "blocks",
      "required": true
    },
    "price": {
      "type": "integer",
      "required": true
    },
    "values": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::product-param-value.product-param-value",
      "mappedBy": "product"
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::product-category.product-category",
      "inversedBy": "products"
    },
    "order": {
      "type": "integer",
      "required": true,
      "default": 1,
      "min": 0
    },
    "sku": {
      "type": "string"
    },
    "sale": {
      "type": "integer",
      "max": 99,
      "min": 1
    }
  }
}
